# ── SplitStellar Environment Variables ─────────────────────
# Copy this file to frontend/.env and fill in your values.

# Soroban Contract ID (deployed on testnet)
VITE_SOROBAN_CONTRACT_ID=CAG5MXEQORC4ZP57WI4WJVXWHP5CZHXXMA77VV63JVSW42GNMJYAMUCJ

# Soroban RPC URL (testnet)
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Stellar Network (testnet | mainnet)
VITE_STELLAR_NETWORK=testnet

# Supabase (optional — mock fallback used when missing)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
